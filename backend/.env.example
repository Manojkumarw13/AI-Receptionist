# AI Receptionist — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Groq API Key for LLM inference (get one at https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# JWT secret key for signing tokens
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_jwt_secret_key_here

# JWT token expiry in minutes (default: 60)
JWT_EXPIRE_MINUTES=60

# ── SEED USERS (Optional) ─────────────────────────────────────────────────────
# Set these to create default demo accounts on first startup.
# Use strong passwords — at least 12 characters with mixed case, numbers, symbols.
SEED_ADMIN_PASSWORD=
SEED_USER_PASSWORD=

# ── EMAIL (Optional) ──────────────────────────────────────────────────────────
# Gmail App Password (not your regular Gmail password).
# See: https://support.google.com/accounts/answer/185833
EMAIL=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here

# SMTP Server settings (defaults to Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ── DATABASE (Optional) ───────────────────────────────────────────────────────
# Defaults to SQLite in backend/ directory (fine for development).
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=sqlite:///receptionist.db

# ── TIMEZONE (Optional) ───────────────────────────────────────────────────────
TIMEZONE=Asia/Kolkata

# ── CONNECTION POOLING (Optional) ─────────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ── PAGINATION (Optional) ─────────────────────────────────────────────────────
PAGE_SIZE=50
MAX_PAGE_SIZE=100

# ── GROQ MODEL (Optional) ─────────────────────────────────────────────────────
# Change if Groq deprecates the default model.
GROQ_MODEL=llama-3.3-70b-versatile
